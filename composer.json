{
    "name": "ironflow-framework/framework",
    "description": "IronFlow — PHP 8.2+ HMVC Framework Core",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "require": {
        "php": ">=8.2",
        "doctrine/dbal": "^4.4",
        "firebase/php-jwt": "^7.0",
        "monolog/monolog": "^3.10",
        "symfony/console": "^8.1",
        "symfony/http-foundation": "^8.1",
        "symfony/var-dumper": "^8.1",
        "twig/twig": "^3.27",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Ironflow\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Ironflow\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
